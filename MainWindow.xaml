<Window x:Class="VirtualKeyboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="虚拟键盘" 
        Width="830" Height="330"
        MinWidth="400" MinHeight="160"
        WindowStyle="None"
        Topmost="True"
        ResizeMode="CanResize"
        Background="#01000000"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        SourceInitialized="Window_SourceInitialized">
    <Window.Resources>
        <Color x:Key="KeyGlowColor">#00FF00</Color>
        <SolidColorBrush x:Key="MainBackgroundBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="MainBorderBrush" Color="#00FF00"/>
        <SolidColorBrush x:Key="DragBarBackgroundBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="TitleForegroundBrush" Color="#00FF00"/>
        <SolidColorBrush x:Key="KeyBackgroundBrush" Color="#3C3C3C"/>
        <SolidColorBrush x:Key="KeyBorderBrush" Color="#00FF00"/>
        <SolidColorBrush x:Key="KeyForegroundBrush" Color="#00FF00"/>
        <SolidColorBrush x:Key="KeyHoverBackgroundBrush" Color="#4A4A4A"/>
        <SolidColorBrush x:Key="KeyPressedBackgroundBrush" Color="#2A2A2A"/>
        <SolidColorBrush x:Key="KeyPressedBorderBrush" Color="#00CC00"/>
        <SolidColorBrush x:Key="ModifierActiveBackgroundBrush" Color="#1A5C1A"/>

        <Style x:Key="ThemeSwitchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FontSizeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="6,0,6,0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="{DynamicResource DragBarBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TitleForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource TitleForegroundBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Viewbox 实现整体缩放 -->
    <Viewbox Stretch="Uniform">
        <!-- 外层边框容器 -->
        <Border x:Name="MainBorder" 
                Background="{DynamicResource MainBackgroundBrush}" 
                BorderBrush="{DynamicResource MainBorderBrush}" 
                BorderThickness="2"
                CornerRadius="10"
                Margin="5">
            <Border.Effect>
                <DropShadowEffect Color="{DynamicResource KeyGlowColor}" Direction="270" ShadowDepth="0" BlurRadius="15" Opacity="0.5"/>
            </Border.Effect>

            <Grid Background="Transparent" Margin="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="195*"/>
                    <ColumnDefinition Width="195*"/>
                    <ColumnDefinition Width="11*"/>
                    <ColumnDefinition Width="184*"/>
                    <ColumnDefinition Width="195*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 拖拽区域 -->
                <Border Grid.Row="0" Grid.ColumnSpan="5" 
                        Background="{DynamicResource DragBarBackgroundBrush}" 
                        CornerRadius="8,8,0,0"
                        Margin="0,0,0,2"
                        Cursor="SizeAll"
                        MouseLeftButtonDown="Border_MouseLeftButtonDown">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource KeyGlowColor}" Direction="270" ShadowDepth="0" BlurRadius="5" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="8,0,0,0">
                            <Button Style="{StaticResource ThemeSwitchButtonStyle}"
                                    Tag="NeonGreen"
                                    ToolTip="霓虹绿主题"
                                    Background="#3C3C3C"
                                    BorderBrush="#00FF00"
                                    Click="ThemeButton_Click"/>
                            <Button Style="{StaticResource ThemeSwitchButtonStyle}"
                                    Tag="IceBlue"
                                    ToolTip="冰蓝主题"
                                    Background="#2A354A"
                                    BorderBrush="#56C6FF"
                                    Click="ThemeButton_Click"/>
                            <Button Style="{StaticResource ThemeSwitchButtonStyle}"
                                    Tag="Purple"
                                    ToolTip="紫色主题"
                                    Background="#3A2F4A"
                                    BorderBrush="#C084FC"
                                    Click="ThemeButton_Click"/>
                            <Button Style="{StaticResource ThemeSwitchButtonStyle}"
                                    Tag="Amber"
                                    ToolTip="琥珀主题"
                                    Background="#4A3824"
                                    BorderBrush="#F59E0B"
                                    Click="ThemeButton_Click"/>
                            <Button Style="{StaticResource ThemeSwitchButtonStyle}"
                                    Tag="ClassicBlack"
                                    ToolTip="暗黑主题"
                                    Background="#1A1A1A"
                                    BorderBrush="#E0E0E0"
                                    Click="ThemeButton_Click"/>
                            <Button Style="{StaticResource ThemeSwitchButtonStyle}"
                                    Tag="ClassicWhite"
                                    ToolTip="明亮主题"
                                    Background="#F9F9F9"
                                    BorderBrush="#333333"
                                    Click="ThemeButton_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource FontSizeButtonStyle}"
                                    Tag="FontSmaller"
                                    Content="A-"
                                    Click="FontSizeButton_Click"/>
                            <TextBlock Text="⋮⋮"
                                       FontSize="16"
                                       Foreground="{DynamicResource TitleForegroundBrush}"
                                       VerticalAlignment="Center"/>
                            <Button Style="{StaticResource FontSizeButtonStyle}"
                                    Tag="FontLarger"
                                    Content="A+"
                                    Click="FontSizeButton_Click"/>
                        </StackPanel>
                        <!-- 关闭按钮 -->
                        <Button x:Name="CloseButton" 
                                Content="✕" 
                                FontSize="14" 
                                FontWeight="Bold"
                                Width="24" 
                                Height="24"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Cursor="Hand"
                                Click="CloseButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TitleForegroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="closeBorder"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Width="{TemplateBinding Width}"
                                                        Height="{TemplateBinding Height}">
                                                    <ContentPresenter x:Name="contentPresenter"
                                                                      HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"
                                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="closeBorder" Property="Background" Value="#FF3333"/>
                                                        <Setter TargetName="contentPresenter" Property="TextElement.Foreground" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="closeBorder" Property="Background" Value="#CC0000"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <!-- 第一行：Esc, 数字键 1-0, -, =, Backspace -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Grid.ColumnSpan="5">
                    <Button Style="{StaticResource SquareKeyStyle}" Content="Esc" FontSize="15"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="1"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="2"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="3"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="4"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="5"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="6"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="7"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="8"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="9"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="0"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="-"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="="/>
                    <Button Style="{StaticResource BackspaceKeyStyle}" Content="←" FontSize="20" Width="72"/>
                </StackPanel>

                <!-- 第二行：Tab, Q-P, [, ] -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Grid.ColumnSpan="5">
                    <Button Style="{StaticResource TabKeyStyle}" Content="Tab" FontSize="15"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="Q"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="W"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="E"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="R"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="T"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="Y"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="U"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="I"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="O"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="P"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="["/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="]"/>
                </StackPanel>

                <!-- 第三行和第四行：使用 Grid 来放置 Enter 键跨两行 -->
                <Grid Grid.Row="3" Grid.RowSpan="2" Grid.ColumnSpan="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 第三行：CapsLock, A-L, ;, ' -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <ToggleButton Style="{StaticResource ToggleKeyStyle}" Content="CAP" FontSize="15"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="A"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="S"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="D"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="F"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="G"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="H"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="J"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="K"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="L"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content=";"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="'"/>
                    </StackPanel>

                    <!-- Enter 键 - 紧贴在第三行右侧，跨两行 -->
                    <Button Style="{StaticResource EnterKeyStyle}"
                            VerticalAlignment="Top" Margin="675,-52,0,0" FontSize="15"/>

                    <!-- 第四行：Shift, Z-M, ,, ., /, Shift -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Style="{StaticResource ShiftKeyStyle}" Content="Shift" FontSize="15"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="Z"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="X"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="C"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="V"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="B"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="N"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="M"/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content=","/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="."/>
                        <Button Style="{StaticResource SquareKeyStyle}" Content="/"/>
                        <Button Style="{StaticResource ShiftKeyStyle}" Content="Shift" FontSize="15" Width="114"/>
                    </StackPanel>
                </Grid>

                <!-- 第五行：Ctrl, Alt, 空格, 方向键 -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Left" Grid.ColumnSpan="5">
                    <Button Style="{StaticResource FunctionKeyStyle}" Content="Ctrl" FontSize="15"/>
                    <Button Style="{StaticResource FunctionKeyStyle}" Content="Alt" FontSize="15"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="`"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="\"/>
                    <Button Style="{StaticResource SpaceKeyStyle}" Content=""/>
                    <!-- 方向键 -->
                    <Button Style="{StaticResource SquareKeyStyle}" Content="↓" FontSize="18"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="↑" FontSize="18"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="←" FontSize="18"/>
                    <Button Style="{StaticResource SquareKeyStyle}" Content="→" FontSize="18"/>
                </StackPanel>
            </Grid>
        </Border>
    </Viewbox>
</Window>
